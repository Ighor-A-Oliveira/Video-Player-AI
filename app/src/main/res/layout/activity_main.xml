<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">
    <Button android:id="@+id/btnSelectFolder" android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Selecionar Pasta" android:layout_centerHorizontal="true" android:layout_marginTop="16dp"/>
    <androidx.recyclerview.widget.RecyclerView android:id="@+id/recyclerView"
        android:layout_width="match_parent" android:layout_height="match_parent" android:layout_below="@id/btnSelectFolder"/>
</RelativeLayout>
