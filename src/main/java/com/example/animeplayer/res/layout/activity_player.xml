<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent" android:background="#000000">
    <androidx.media3.ui.PlayerView android:id="@+id/player_view"
        android:layout_width="match_parent" android:layout_height="match_parent" app:resize_mode="fit"/>
    <ImageButton android:id="@+id/btn_tracks" android:layout_width="56dp" android:layout_height="56dp"
        android:layout_gravity="top|end" android:layout_margin="16dp" android:src="@android:drawable/ic_menu_manage"
        android:background="?attr/selectableItemBackgroundBorderless" app:tint="#FFFFFF"/>
</FrameLayout>